<rml>
<head>
    <title>Shader Configuration</title>
    <link type="text/rcss" href="base.rcss"/>
    <link type="text/rcss" href="shaders.rcss"/>
</head>
<body data-model="shaders">
    <div id="shader-panel">
        <h1>SHADER CONFIGURATION</h1>
        <div class="divider"></div>

        <!-- Shader System Mode -->
        <div class="section">
            <h2>Shader System</h2>
            <div class="control-row">
                <select data-value="is_libretro">
                    <option value="0">Internal Shaders</option>
                    <option value="1">Libretro Shaders</option>
                </select>
            </div>
        </div>

        <div class="divider"></div>

        <!-- Scale Mode (Internal only) -->
        <div data-if="!is_libretro" class="section">
            <h2>Scale Mode</h2>
            <div class="control-row">
                <input type="radio" name="scale" value="0" data-checked="scale_mode"/>
                <label>{{scale_mode_name_0}}</label>
            </div>
            <div class="control-row">
                <input type="radio" name="scale" value="1" data-checked="scale_mode"/>
                <label>{{scale_mode_name_1}}</label>
            </div>
            <div class="control-row">
                <input type="radio" name="scale" value="2" data-checked="scale_mode"/>
                <label>{{scale_mode_name_2}}</label>
            </div>
            <div class="control-row">
                <input type="radio" name="scale" value="3" data-checked="scale_mode"/>
                <label>{{scale_mode_name_3}}</label>
            </div>
            <div class="control-row">
                <input type="radio" name="scale" value="4" data-checked="scale_mode"/>
                <label>{{scale_mode_name_4}}</label>
            </div>
        </div>

        <!-- ═══ Two-Panel Layout (Libretro only) ═══ -->
        <!-- Pattern from control_mapping: inline-block + white-space:nowrap -->
        <div data-if="is_libretro" class="columns">
            <div class="column col-left">
                <h2>Shader Presets ({{preset_count}})</h2>
                <div class="search-row">
                    <label>Search:</label>
                    <input type="text" id="preset-search" size="40" data-value="search_filter"/>
                </div>
                <div id="preset-list">
                    <div data-if="filtered_presets.size == 0" class="status-warn">
                        No matching presets found.
                    </div>
                    <div data-for="preset : filtered_presets"
                         data-if="preset.index >= 0"
                         class="preset-item"
                         data-class-selected="preset.index == current_preset">
                    {{preset.name}} <span class="chain-select-btn" data-event-click="select_preset(preset.index)">Sel</span> <span class="chain-append-btn" data-event-click="chain_append(preset.index)">+A</span> <span class="chain-prepend-btn" data-event-click="chain_prepend(preset.index)">+P</span>
                    </div>
                </div>
            </div>
            <div class="column col-right">
                <h2>Active Chain ({{chain_pass_count}} passes)</h2>
                <div data-if="chain_pass_count > 0" id="chain-pass-list">
                    <div id="chain-pass-table">
                        <div data-for="pass : chain_passes"
                             data-if="pass.index >= 0"
                             class="chain-pass-row">
                            <div class="chain-pass-name-cell">{{pass.index + 1}}. {{pass.name}}</div>
                            <div class="chain-pass-btn-cell">
                                <span class="chain-btn" data-event-click="chain_move_up(pass.index)">Up</span>
                                <span class="chain-btn" data-event-click="chain_move_down(pass.index)">Dn</span>
                                <span class="chain-btn chain-btn-remove" data-event-click="chain_remove_pass(pass.index)">Del</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div data-if="chain_pass_count > 0" id="chain-actions-bar">
                    <div class="chain-action-cell"><span class="chain-save-btn" data-event-click="chain_save()">Save Chain</span></div>
                    <div class="chain-action-cell"><span class="chain-clear-btn" data-event-click="chain_clear()">Clear All</span></div>
                </div>
                <div data-if="chain_pass_count == 0" class="status-info">
                    No passes in chain. Use +A / +P to add.
                </div>
            </div>
        </div>




        <!-- ═══ Shader Parameters Panel (Libretro, full width below) ═══ -->
        <div data-if="is_libretro" id="shader-params-panel">
            <div data-if="shader_param_count > 0">
                <h2>Shader Parameters ({{shader_param_count}})</h2>
                <div id="shader-params-list">
                    <div id="shader-params-table">
                        <div data-for="param : shader_params"
                             data-if="param.index >= 0"
                             class="param-row">
                            <div class="param-name-cell">{{param.desc}}</div>
                            <div class="param-controls-cell">
                                <span class="param-btn" data-event-click="param_dec(param.index)">-</span>
                                <span class="param-value">{{param.value_str}}</span>
                                <span class="param-btn" data-event-click="param_inc(param.index)">+</span>
                                <span class="param-btn param-btn-reset" data-event-click="param_reset(param.index)">R</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div data-if="shader_param_count == 0" class="status-info">
                No shader parameters available.
            </div>
        </div>

        <div class="divider"></div>
        <p class="hint">Press F2 to close this menu</p>
    </div>
</body>
</rml>
