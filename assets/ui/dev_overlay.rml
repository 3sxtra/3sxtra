<rml>
<head>
    <title>Dev Overlay</title>
    <link type="text/rcss" href="base.rcss"/>
    <link type="text/rcss" href="dev_overlay.rcss"/>
</head>
<body data-model="dev_overlay">
    <div id="dev-panel">
        <handle move_target="dev-panel">
            <h1>🔧 DEV OVERLAY (F9)</h1>
        </handle>
        <div class="divider"></div>

        <!-- Document list -->
        <div class="section">
            <div class="section-header">
                <h2>DOCUMENTS</h2>
                <button class="btn-sm" data-event-click="refresh_docs">↻ Refresh</button>
            </div>
            <div class="doc-list" data-if="doc_count > 0">
                <div data-for="doc : doc_list"
                     class="doc-item"
                     data-class-doc-selected="selected_doc == doc.index"
                     data-class-doc-hidden="!doc.visible"
                     data-event-click="select_doc(doc.index)">
                    <span class="doc-ctx">{{doc.context_label}}</span>
                    <span class="doc-name">{{doc.name}}</span>
                    <span class="doc-vis" data-if="doc.visible">●</span>
                    <span class="doc-vis-off" data-if="!doc.visible">○</span>
                </div>
            </div>
            <p class="status-hint" data-if="doc_count == 0">No documents loaded. Click Refresh.</p>
        </div>

        <div class="divider"></div>

        <!-- Element tree -->
        <div class="section">
            <h2>ELEMENT TREE</h2>
            <div class="elem-list" data-if="elem_count > 0">
                <div data-for="el : elem_list"
                     data-if="el.index < elem_count"
                     class="elem-item"
                     data-class-elem-selected="selected_elem == el.index"
                     data-event-click="select_elem(el.index)"
                     data-style-padding-left="(el.depth * 12) + 'dp'">
                    {{el.label}}
                </div>
            </div>
            <p class="status-hint" data-if="elem_count == 0">Select a document above.</p>
        </div>

        <div class="divider"></div>

        <!-- Property inspector -->
        <div class="section" data-if="has_selection">
            <h2>INSPECTOR</h2>
            <p class="elem-breadcrumb">{{sel_path}}</p>

            <!-- Visibility toggle -->
            <div class="control-row">
                <input type="checkbox" data-checked="sel_visible"/>
                <label>Visible</label>
            </div>

            <div class="divider"></div>

            <!-- Display & Position -->
            <h3>Layout</h3>
            <div class="control-row">
                <label>Display</label>
                <input type="text" data-value="sel_display"/>
            </div>
            <div class="control-row">
                <label>Position</label>
                <input type="text" data-value="sel_position"/>
            </div>
            <div class="control-row">
                <label>Top</label>
                <input type="text" data-value="sel_top"/>
            </div>
            <div class="control-row">
                <label>Right</label>
                <input type="text" data-value="sel_right"/>
            </div>
            <div class="control-row">
                <label>Bottom</label>
                <input type="text" data-value="sel_bottom"/>
            </div>
            <div class="control-row">
                <label>Left</label>
                <input type="text" data-value="sel_left"/>
            </div>

            <div class="divider"></div>

            <!-- Margins -->
            <h3>Margin</h3>
            <div class="control-row">
                <label>Top</label>
                <input type="range" min="-200" max="200" step="1" data-value="sel_margin_top"/>
                <span class="value-display">{{sel_margin_top}}</span>
            </div>
            <div class="control-row">
                <label>Right</label>
                <input type="range" min="-200" max="200" step="1" data-value="sel_margin_right"/>
                <span class="value-display">{{sel_margin_right}}</span>
            </div>
            <div class="control-row">
                <label>Bottom</label>
                <input type="range" min="-200" max="200" step="1" data-value="sel_margin_bottom"/>
                <span class="value-display">{{sel_margin_bottom}}</span>
            </div>
            <div class="control-row">
                <label>Left</label>
                <input type="range" min="-200" max="200" step="1" data-value="sel_margin_left"/>
                <span class="value-display">{{sel_margin_left}}</span>
            </div>

            <div class="divider"></div>

            <!-- Padding -->
            <h3>Padding</h3>
            <div class="control-row">
                <label>Top</label>
                <input type="range" min="0" max="100" step="1" data-value="sel_padding_top"/>
                <span class="value-display">{{sel_padding_top}}</span>
            </div>
            <div class="control-row">
                <label>Right</label>
                <input type="range" min="0" max="100" step="1" data-value="sel_padding_right"/>
                <span class="value-display">{{sel_padding_right}}</span>
            </div>
            <div class="control-row">
                <label>Bottom</label>
                <input type="range" min="0" max="100" step="1" data-value="sel_padding_bottom"/>
                <span class="value-display">{{sel_padding_bottom}}</span>
            </div>
            <div class="control-row">
                <label>Left</label>
                <input type="range" min="0" max="100" step="1" data-value="sel_padding_left"/>
                <span class="value-display">{{sel_padding_left}}</span>
            </div>

            <div class="divider"></div>

            <!-- Size -->
            <h3>Size</h3>
            <div class="control-row">
                <label>Width</label>
                <input type="text" data-value="sel_width"/>
            </div>
            <div class="control-row">
                <label>Height</label>
                <input type="text" data-value="sel_height"/>
            </div>

            <div class="divider"></div>

            <!-- Border -->
            <h3>Border</h3>
            <div class="control-row">
                <label>Width</label>
                <input type="range" min="0" max="10" step="1" data-value="sel_border_width"/>
                <span class="value-display">{{sel_border_width}}</span>
            </div>
            <div class="control-row">
                <label>Color</label>
                <input type="text" data-value="sel_border_color"/>
            </div>
            <div class="control-row">
                <label>Radius</label>
                <input type="range" min="0" max="50" step="1" data-value="sel_border_radius"/>
                <span class="value-display">{{sel_border_radius}}</span>
            </div>

            <div class="divider"></div>

            <!-- Background -->
            <h3>Background</h3>
            <div class="control-row">
                <label>Color</label>
                <input type="text" data-value="sel_bg_color"/>
            </div>

            <div class="divider"></div>

            <!-- Typography -->
            <h3>Typography</h3>
            <div class="control-row">
                <label>Font Size</label>
                <input type="range" min="6" max="80" step="1" data-value="sel_font_size"/>
                <span class="value-display">{{sel_font_size}}</span>
            </div>
            <div class="control-row">
                <label>Color</label>
                <input type="text" data-value="sel_color"/>
            </div>
            <div class="control-row">
                <label>Opacity</label>
                <input type="range" min="0" max="1" step="0.05" data-value="sel_opacity"/>
                <span class="value-display">{{sel_opacity}}</span>
            </div>

            <div class="divider"></div>

            <!-- Text -->
            <h3>Text</h3>
            <div class="control-row">
                <label>Align</label>
                <input type="text" data-value="sel_text_align"/>
            </div>
            <div class="control-row">
                <label>Line Ht</label>
                <input type="range" min="8" max="60" step="1" data-value="sel_line_height"/>
                <span class="value-display">{{sel_line_height}}</span>
            </div>
            <div class="control-row">
                <label>Spacing</label>
                <input type="range" min="-5" max="20" step="1" data-value="sel_letter_spacing"/>
                <span class="value-display">{{sel_letter_spacing}}</span>
            </div>

            <div class="divider"></div>

            <!-- Flex -->
            <h3>Flex</h3>
            <div class="control-row">
                <label>Direction</label>
                <input type="text" data-value="sel_flex_direction"/>
            </div>
            <div class="control-row">
                <label>Justify</label>
                <input type="text" data-value="sel_justify_content"/>
            </div>
            <div class="control-row">
                <label>Align</label>
                <input type="text" data-value="sel_align_items"/>
            </div>
            <div class="control-row">
                <label>Gap</label>
                <input type="range" min="0" max="50" step="1" data-value="sel_gap"/>
                <span class="value-display">{{sel_gap}}</span>
            </div>

            <div class="divider"></div>

            <!-- Overflow -->
            <h3>Overflow</h3>
            <div class="control-row">
                <label>Mode</label>
                <input type="text" data-value="sel_overflow"/>
            </div>

            <div class="divider"></div>

            <!-- Computed Info (read-only) -->
            <h3>Info</h3>
            <div class="info-row">
                <span class="info-label">Tag</span>
                <span class="info-value">{{info_tag}}</span>
            </div>
            <div class="info-row" data-if="info_id != ''">
                <span class="info-label">ID</span>
                <span class="info-value info-accent">{{info_id}}</span>
            </div>
            <div class="info-row" data-if="info_classes != ''">
                <span class="info-label">Classes</span>
                <span class="info-value">{{info_classes}}</span>
            </div>
            <div class="info-row">
                <span class="info-label">Box</span>
                <span class="info-value">{{info_box}}</span>
            </div>
            <div class="info-row">
                <span class="info-label">Children</span>
                <span class="info-value">{{info_children}}</span>
            </div>
            <div class="info-row" data-if="info_source != ''">
                <span class="info-label">Source</span>
                <span class="info-value">{{info_source}}</span>
            </div>

            <div class="divider"></div>

            <!-- Actions -->
            <div class="button-row">
                <button data-event-click="reset_elem">Reset</button>
                <button class="btn-accent" data-event-click="copy_rcss">📋 Copy RCSS</button>
            </div>
        </div>

        <div data-if="!has_selection" class="no-selection">
            <p class="status-hint">Select an element to inspect.</p>
        </div>

        <div class="divider"></div>
        <p class="hint">Drag header to move • Press F9 to close</p>
    </div>
</body>
</rml>
