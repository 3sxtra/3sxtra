/* Mods menu stylesheet — 3SXtra RmlUi overlay
 * Two-column layout uses the same pattern as shaders.rcss:
 *   .columns  { display: block; white-space: nowrap; }
 *   .column   { display: inline-block; vertical-align: top; white-space: normal; }
 */

body {
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 191);
    display: flex;
    justify-content: center;
    align-items: center;
}

#mods-panel {
    display: block;
    width: 85vw;
    max-height: 88vh;
    background-color: rgba(15, 15, 20, 242);
    border-width: 1dp;
    border-color: #444;
    border-radius: 10dp;
    padding: 12dp 16dp;
    overflow-y: auto;
}

/* ── Two-Column Layout (same pattern as shaders.rcss) ─────── */

.columns {
    display: block;
    white-space: nowrap;
}

.column {
    display: inline-block;
    vertical-align: top;
    padding: 2dp;
    white-space: normal;
}

.col-left {
    width: 48%;
}

.col-right {
    width: 48%;
    border-left-width: 1dp;
    border-left-color: #333;
    padding-left: 6dp;
}

/* Title */
#mods-panel h1 {
    font-size: 18dp;
    color: #ff9933;
    margin-bottom: 6dp;
    text-align: center;
    white-space: nowrap;
}

/* Section headers */
#mods-panel h2 {
    font-size: 13dp;
    color: #888;
    margin-top: 6dp;
    margin-bottom: 5dp;
    text-transform: uppercase;
    letter-spacing: 1dp;
    white-space: nowrap;
}

/* Sections */
.section {
    display: block;
    margin-bottom: 2dp;
}

/* Horizontal dividers */
.divider {
    display: block;
    height: 1dp;
    background-color: #333;
    margin-top: 3dp;
    margin-bottom: 3dp;
}

/* Control rows */
.control-row {
    display: block;
    padding: 3dp 6dp;
    white-space: nowrap;
}

.control-row input {
    display: inline-block;
    vertical-align: middle;
}

.control-row label {
    display: inline-block;
    vertical-align: middle;
}

.control-row:hover {
    background-color: rgba(255, 255, 255, 13);
    border-radius: 3dp;
}

/* Labels */
label {
    font-size: 14dp;
    color: #dddddd;
    cursor: pointer;
    white-space: nowrap;
}

/* Indent for sub-options */
.indent {
    display: block;
    margin-left: 12dp;
}

/* Disabled state */
.disabled {
    opacity: 0.35;
}

/* ─── Select/Dropdown ─── */

select {
    display: block;
    width: 100%;
    height: 26dp;
    background-color: #2a2a30;
    border-width: 1dp;
    border-color: #555;
    border-radius: 4dp;
    color: #ddd;
    font-size: 13dp;
}

select selectvalue {
    width: auto;
    height: 26dp;
    padding: 6dp 10dp 0 10dp;
    color: #ddd;
}

select selectarrow {
    width: 0;
    height: 0;
}

select:hover {
    border-color: #ff9933;
}

select selectbox {
    width: 100%;
    background-color: #1a1a20;
    border-width: 1dp;
    border-color: #555;
}

select selectbox option {
    padding: 6dp 8dp;
    color: #ddd;
}

select selectbox option:hover {
    background-color: #ff993344;
}

select selectbox option:checked {
    background-color: #ff993366;
    color: #fff;
}

/* Status indicator text */
.status-ok {
    color: #66ff66;
    font-size: 13dp;
}

.status-warn {
    color: #ffcc33;
    font-size: 13dp;
    display: block;
    margin-bottom: 4dp;
    white-space: nowrap;
}

/* Footer hint text */
.hint {
    font-size: 12dp;
    color: #555;
    margin-top: 8dp;
    text-align: center;
    white-space: nowrap;
}

/* Scrollbar styling */
scrollbarvertical {
    width: 6dp;
}

scrollbarvertical sliderbar {
    background-color: #555;
    border-radius: 3dp;
}

scrollbarvertical sliderbar:hover {
    background-color: #777;
}

scrollbarvertical slidertrack {
    background-color: #222;
}
